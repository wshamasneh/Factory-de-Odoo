{
  "module_name": "uni_fee",
  "odoo_version": "17.0",
  "version": "17.0.1.0.0",
  "depends": ["base", "mail", "account"],
  "models": [
    {
      "name": "fee.invoice",
      "fields": [
        {
          "name": "name",
          "type": "Char",
          "required": true,
          "string": "Reference"
        },
        {
          "name": "old_ref",
          "type": "Char",
          "required": false,
          "string": "Old Reference"
        },
        {
          "name": "amount",
          "type": "Float",
          "required": true,
          "string": "Amount"
        },
        {
          "name": "student_id",
          "type": "Many2one",
          "comodel_name": "res.partner",
          "required": true,
          "string": "Student",
          "ondelete": "restrict"
        },
        {
          "name": "state",
          "type": "Selection",
          "selection": [
            ["draft", "Draft"],
            ["confirmed", "Confirmed"],
            ["paid", "Paid"],
            ["cancelled", "Cancelled"]
          ],
          "required": true,
          "default": "draft",
          "string": "Status"
        },
        {
          "name": "description",
          "type": "Text",
          "required": false,
          "string": "Description"
        },
        {
          "name": "due_date",
          "type": "Date",
          "required": false,
          "string": "Due Date"
        },
        {
          "name": "is_overdue",
          "type": "Boolean",
          "compute": "_compute_is_overdue",
          "store": true,
          "string": "Is Overdue"
        }
      ],
      "security": {
        "roles": ["viewer", "editor", "manager"],
        "acl": {
          "viewer": {"create": false, "read": true, "write": false, "unlink": false},
          "editor": {"create": true, "read": true, "write": true, "unlink": false},
          "manager": {"create": true, "read": true, "write": true, "unlink": true}
        }
      },
      "approval": {
        "levels": [
          {"name": "submitted", "role": "editor"},
          {"name": "approved", "role": "manager"}
        ]
      },
      "webhooks": {
        "watched_fields": ["state", "amount"]
      },
      "constraints": [
        {
          "name": "check_amount_positive",
          "type": "check",
          "expression": "amount > 0",
          "message": "Amount must be positive"
        }
      ]
    },
    {
      "name": "fee.payment",
      "fields": [
        {
          "name": "name",
          "type": "Char",
          "required": true,
          "string": "Payment Reference"
        },
        {
          "name": "invoice_id",
          "type": "Many2one",
          "comodel_name": "fee.invoice",
          "required": true,
          "string": "Invoice",
          "ondelete": "cascade"
        },
        {
          "name": "amount",
          "type": "Float",
          "required": true,
          "string": "Amount Paid"
        },
        {
          "name": "payment_date",
          "type": "Date",
          "required": true,
          "string": "Payment Date"
        }
      ]
    }
  ],
  "cron_jobs": [
    {
      "name": "check_overdue_invoices",
      "model": "fee.invoice",
      "method": "_cron_check_overdue",
      "interval_number": 1,
      "interval_type": "days"
    }
  ],
  "reports": [
    {
      "name": "fee_invoice_report",
      "model": "fee.invoice",
      "report_type": "qweb-pdf",
      "template": "uni_fee.report_fee_invoice"
    }
  ]
}
