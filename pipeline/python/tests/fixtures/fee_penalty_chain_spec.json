{
  "module_name": "test_fee",
  "module_title": "Test Fee",
  "summary": "Test fee module with penalty chain",
  "author": "Test",
  "website": "https://test.example.com",
  "license": "LGPL-3",
  "category": "Accounting",
  "odoo_version": "17.0",
  "depends": ["base"],
  "application": true,
  "models": [
    {
      "name": "fee.invoice",
      "description": "Fee Invoice",
      "fields": [
        {"name": "student_id", "type": "Many2one", "comodel_name": "uni.student", "required": true},
        {"name": "amount", "type": "Float"}
      ]
    },
    {
      "name": "uni.student",
      "description": "Student",
      "fields": [
        {"name": "name", "type": "Char", "required": true},
        {"name": "invoice_ids", "type": "One2many", "comodel_name": "fee.invoice", "inverse_name": "student_id"}
      ]
    }
  ],
  "computation_chains": [
    {
      "chain_id": "fee_penalty",
      "description": "Overdue -> Penalty -> Total Balance",
      "steps": [
        {
          "model": "fee.invoice",
          "field": "is_overdue",
          "type": "Boolean",
          "source": "direct_input",
          "description": "Whether invoice is overdue"
        },
        {
          "model": "fee.invoice",
          "field": "penalty_amount",
          "type": "Float",
          "source": "computation",
          "depends": ["is_overdue", "amount"],
          "description": "Calculate penalty based on overdue status"
        },
        {
          "model": "uni.student",
          "field": "total_balance",
          "type": "Float",
          "source": "aggregation",
          "aggregation": "sum",
          "depends": ["invoice_ids.penalty_amount", "invoice_ids.amount"],
          "description": "Sum of all invoice amounts plus penalties"
        }
      ]
    }
  ],
  "wizards": []
}
