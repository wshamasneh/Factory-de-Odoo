{
  "module_name": "integration_test",
  "module_title": "Integration Test Module",
  "odoo_version": "17.0",
  "version": "17.0.1.0.0",
  "summary": "E2E integration test for schema alignment verification",
  "author": "Test Author",
  "website": "https://example.com",
  "license": "LGPL-3",
  "category": "Technical",
  "application": true,
  "depends": ["base", "mail"],
  "models": [
    {
      "name": "integration.test.order",
      "description": "Test order model with relational fields and computed values",
      "fields": [
        {
          "name": "name",
          "type": "Char",
          "required": true,
          "string": "Order Reference"
        },
        {
          "name": "partner_id",
          "type": "Many2one",
          "comodel_name": "res.partner",
          "required": true,
          "string": "Customer",
          "ondelete": "restrict"
        },
        {
          "name": "line_ids",
          "type": "One2many",
          "comodel_name": "integration.test.order.line",
          "inverse_name": "order_id",
          "string": "Order Lines"
        },
        {
          "name": "total_amount",
          "type": "Monetary",
          "string": "Total Amount",
          "compute": "_compute_total_amount",
          "depends": ["line_ids.subtotal"],
          "store": true
        },
        {
          "name": "currency_id",
          "type": "Many2one",
          "comodel_name": "res.currency",
          "string": "Currency",
          "default": "lambda self: self.env.company.currency_id.id"
        },
        {
          "name": "state",
          "type": "Selection",
          "selection": [
            ["draft", "Draft"],
            ["confirmed", "Confirmed"],
            ["done", "Done"],
            ["cancelled", "Cancelled"]
          ],
          "required": true,
          "default": "draft",
          "string": "Status"
        },
        {
          "name": "order_date",
          "type": "Date",
          "string": "Order Date",
          "default": "fields.Date.context_today"
        },
        {
          "name": "notes",
          "type": "Text",
          "string": "Internal Notes"
        }
      ],
      "constraints": [
        {
          "name": "check_total_positive",
          "type": "check",
          "expression": "total_amount >= 0",
          "message": "Total amount cannot be negative"
        }
      ]
    },
    {
      "name": "integration.test.order.line",
      "description": "Test order line with computed subtotal",
      "fields": [
        {
          "name": "name",
          "type": "Char",
          "required": true,
          "string": "Description"
        },
        {
          "name": "order_id",
          "type": "Many2one",
          "comodel_name": "integration.test.order",
          "required": true,
          "string": "Order",
          "ondelete": "cascade"
        },
        {
          "name": "quantity",
          "type": "Float",
          "required": true,
          "default": 1.0,
          "string": "Quantity"
        },
        {
          "name": "unit_price",
          "type": "Monetary",
          "required": true,
          "string": "Unit Price"
        },
        {
          "name": "currency_id",
          "type": "Many2one",
          "comodel_name": "res.currency",
          "string": "Currency",
          "related": "order_id.currency_id"
        },
        {
          "name": "subtotal",
          "type": "Monetary",
          "string": "Subtotal",
          "compute": "_compute_subtotal",
          "depends": ["quantity", "unit_price"],
          "store": true
        }
      ]
    }
  ],
  "security": {
    "roles": ["manager", "user", "readonly"],
    "acl": {},
    "defaults": {
      "manager": "crud",
      "user": "cru",
      "readonly": "r"
    }
  },
  "workflow": [
    {
      "model": "integration.test.order",
      "states": ["draft", "confirmed", "done", "cancelled"],
      "transitions": [
        {"from": "draft", "to": "confirmed", "action": "action_confirm", "conditions": ""},
        {"from": "confirmed", "to": "done", "action": "action_done", "conditions": ""},
        {"from": "draft", "to": "cancelled", "action": "action_cancel", "conditions": ""},
        {"from": "confirmed", "to": "cancelled", "action": "action_cancel", "conditions": ""}
      ]
    }
  ],
  "business_rules": [
    "Orders can only be confirmed if they have at least one line item",
    "Cancelled orders cannot be modified",
    "Total amount is automatically computed from line subtotals"
  ],
  "view_hints": [
    {
      "model": "integration.test.order",
      "view_type": "form",
      "key_fields": ["name", "partner_id", "state", "total_amount"],
      "notes": "Show status bar at top, lines in notebook tab"
    },
    {
      "model": "integration.test.order.line",
      "view_type": "tree",
      "key_fields": ["name", "quantity", "unit_price", "subtotal"],
      "notes": "Inline editable tree inside order form"
    }
  ],
  "computation_chains": [],
  "cron_jobs": [
    {
      "name": "auto_cancel_old_drafts",
      "model": "integration.test.order",
      "model_name": "integration.test.order",
      "method": "_cron_cancel_old_drafts",
      "interval_number": 1,
      "interval_type": "days"
    }
  ],
  "reports": [
    {
      "name": "order_report",
      "model": "integration.test.order",
      "model_name": "integration.test.order",
      "report_type": "qweb-pdf",
      "template": "integration_test.report_order",
      "xml_id": "report_order"
    }
  ],
  "notifications": [],
  "portal": null,
  "controllers": []
}
