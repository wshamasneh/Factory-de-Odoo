{
  "module_name": "uni_fee",
  "odoo_version": "17.0",
  "version": "17.0.1.0.0",
  "depends": ["base", "mail"],
  "models": [
    {
      "name": "fee.invoice",
      "fields": [
        {
          "name": "name",
          "type": "Char",
          "required": true,
          "string": "Reference"
        },
        {
          "name": "amount",
          "type": "Float",
          "required": true,
          "string": "Amount"
        },
        {
          "name": "state",
          "type": "Selection",
          "selection": [
            ["draft", "Draft"],
            ["confirmed", "Confirmed"],
            ["paid", "Paid"]
          ],
          "required": true,
          "default": "draft",
          "string": "Status"
        },
        {
          "name": "discount",
          "type": "Float",
          "required": false,
          "string": "Discount"
        }
      ],
      "security": {
        "roles": ["viewer", "editor"],
        "acl": {
          "viewer": {"create": false, "read": true, "write": false, "unlink": false},
          "editor": {"create": true, "read": true, "write": true, "unlink": false}
        }
      }
    }
  ]
}
