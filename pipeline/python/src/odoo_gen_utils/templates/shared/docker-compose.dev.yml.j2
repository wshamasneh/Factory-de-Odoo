{# docker-compose.dev.yml.j2 -- Per-module development environment #}
services:
  db:
    image: postgres:{{ postgres_version | default('16') }}
    environment:
      POSTGRES_USER: {{ db_user | default('odoo') }}
      POSTGRES_PASSWORD: {{ db_password | default('odoo') }}
      POSTGRES_DB: {{ module_name }}_dev
    ports:
      - "{{ db_port | default('5432') }}:5432"
    volumes:
      - {{ module_name }}_pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ db_user | default('odoo') }} -d {{ module_name }}_dev"]
      interval: 5s
      timeout: 3s
      retries: 5

  odoo:
    image: odoo:{{ odoo_version | default('17.0') }}
    depends_on:
      db:
        condition: service_healthy
    ports:
      - "{{ odoo_port | default('8069') }}:8069"
      - "{{ longpolling_port | default('8072') }}:8072"
    environment:
      HOST: db
      USER: {{ db_user | default('odoo') }}
      PASSWORD: {{ db_password | default('odoo') }}
    volumes:
      - ./:/mnt/extra-addons/{{ module_name }}
{% for dep_path in extra_addon_paths | default([]) %}
      - {{ dep_path }}:/mnt/extra-addons/{{ dep_path.split('/')[-1] }}
{% endfor %}
      - {{ module_name }}_odoo_data:/var/lib/odoo
    command: >-
      --database={{ module_name }}_dev
      --db_host=db
      --db_user={{ db_user | default('odoo') }}
      --db_password={{ db_password | default('odoo') }}
      --addons-path=/mnt/extra-addons,/usr/lib/python3/dist-packages/odoo/addons
      --dev=reload,qweb,xml
      --init={{ module_name }}
{% if extra_depends | default([]) %}
      --load={{ extra_depends | join(',') }}
{% endif %}

volumes:
  {{ module_name }}_pgdata:
  {{ module_name }}_odoo_data:
