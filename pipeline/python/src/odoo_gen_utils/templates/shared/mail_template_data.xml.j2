<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
{% for template in notification_templates %}
    <record id="{{ template.xml_id }}" model="mail.template">
        <field name="name">{{ template.name }}</field>
        <field name="model_id" ref="model_{{ template.model_xml_id }}"/>
        <field name="subject">{{ template.subject }}</field>
        <field name="email_to">{{ template.email_to }}</field>
        <field name="body_html" type="html">
            <![CDATA[
            <div style="margin: 0px; padding: 0px;">
                <p>{{ template.body_intro | replace(']]>', ']]]]><![CDATA[>') }}</p>
                <table style="border-collapse: collapse; width: 100%;">
{% for field in template.body_fields %}
                    <tr>
                        <td style="padding: 8px; border: 1px solid #ddd; font-weight: bold;">{{ field.label }}</td>
                        <td style="padding: 8px; border: 1px solid #ddd;">${{ '{' }}object.{{ field.name }}{{ '}' }}</td>
                    </tr>
{% endfor %}
                </table>
            </div>
            ]]>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>
{% endfor %}
</odoo>
