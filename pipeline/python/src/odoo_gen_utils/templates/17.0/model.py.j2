    def {{ approval_submit_action.name }}(self):
        """Submit record for approval."""
        self.ensure_one()
        if self.{{ approval_state_field_name }} != '{{ approval_submit_action.from_state }}':
            raise UserError(_("Record must be in '{{ approval_submit_action.from_state_label }}' state to submit."))
        self.with_context(_force_state=True).write({
            '{{ approval_state_field_name }}': '{{ approval_submit_action.to_state }}',
        })
{% if approval_submit_action.get('notification') %}
        # Notification -- AFTER successful state change
        try:
            template = self.env.ref('{{ module_name }}.{{ approval_submit_action.notification.template_xml_id }}')
            template.send_mail(self.id, force_send=False)
        except Exception:
            _logger.warning(
                "Failed to send notification for %s #%s",
                self._name, self.id, exc_info=True,
            )
{% endif %}
